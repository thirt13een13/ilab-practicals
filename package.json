{
  "name": "ilab-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend:dev": "cd ilab-frontend && npm run dev",
    "frontend:build": "cd ilab-frontend && npm run build",
    "docker:manager": "cd docker-manager && node src/server.js",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "experiments:build": "bash scripts/build-all-experiments.sh",
    "dev": "concurrently \"npm run supabase:start\" \"npm run frontend:dev\" \"npm run docker:manager\"",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}